{
  "manifest_version": 3,
  "name": "VisionOCR AI",
  "version": "1.0",
  "description": "Extract text from any image using Google Vision AI.",
  "permissions": ["activeTab", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
